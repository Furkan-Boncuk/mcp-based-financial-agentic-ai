# PostgreSQL Database Configuration (DB-per-service in production, unified local for development)
# LOCAL DEVELOPMENT: Run single PostgreSQL instance, each service uses separate schema.
# PRODUCTION: Each service has dedicated PostgreSQL database with separate credentials.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Service-Specific Database Schemas (used locally with single PostgreSQL instance)
AUTH_DB_SCHEMA=auth_service
CONVERSATION_DB_SCHEMA=conversation_service
AGENT_DB_SCHEMA=financial_agent_service

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
# Leave empty for local development, set in production.
REDIS_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Auth Service - JWT Keys
AUTH_JWT_PRIVATE_KEY=<base64-encoded-rsa-private-key>
AUTH_JWT_PUBLIC_KEY=<base64-encoded-rsa-public-key>
AUTH_JWT_ISSUER=https://auth.example.com
AUTH_JWT_AUDIENCE=https://api.example.com

# API Gateway - JWT Validation
# For local direct validation, use the same public key, issuer, and audience as auth-service.
GATEWAY_JWT_PUBLIC_KEY=<base64-encoded-rsa-public-key>
GATEWAY_JWT_ISSUER=https://auth.example.com
GATEWAY_JWT_AUDIENCE=https://api.example.com

# Service Ports
AUTH_SERVICE_PORT=8081
CONVERSATION_SERVICE_PORT=8082
FINANCIAL_AGENT_SERVICE_PORT=8083
GATEWAY_PORT=8080

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Correlation-ID,Idempotency-Key
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_PER_USER_PER_MINUTE=100
RATE_LIMIT_PER_USER_BURST_CAPACITY=100
RATE_LIMIT_PER_IP_PER_MINUTE=1000
RATE_LIMIT_PER_IP_BURST_CAPACITY=1000
RATE_LIMIT_MESSAGE_SUBMIT_PER_MINUTE=20
RATE_LIMIT_MESSAGE_SUBMIT_BURST_CAPACITY=20

# LLM Configuration (placeholder)
LLM_PROVIDER=openai
LLM_API_KEY=<your-llm-api-key>
LLM_MODEL=gpt-4-turbo

# Financial Data APIs (placeholder)
FRED_API_KEY=<your-fred-api-key>
TRADING_VIEW_API_KEY=<your-trading-view-api-key>

# Environment
SPRING_PROFILES_ACTIVE=local
