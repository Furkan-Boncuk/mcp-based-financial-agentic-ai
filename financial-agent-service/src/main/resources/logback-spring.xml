<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="financial-agent-service"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}","service":"${appName}","level":"%level","logger":"%logger{36}","correlationId":"%X{correlationId}","userId":"%X{userId}","agentTaskId":"%X{agentTaskId}","message":"%replace(%msg){'[\r\n\"]','_'}"}%n</pattern>
        </encoder>
    </appender>

    <springProfile name="local,dev">
        <logger name="com.financialagent" level="DEBUG"/>
    </springProfile>

    <springProfile name="prod">
        <logger name="com.financialagent" level="INFO"/>
    </springProfile>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
